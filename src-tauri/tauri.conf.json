{
  "productName": "TZ Tool",
  "version": "0.1.0",
  "identifier": "com.tztools.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ТЗ Tool",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#f5f4f1"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
